# Public demo configuration.
# Replace placeholders before running your local app.
# Do not commit a real .env file.

EXPO_PUBLIC_CHAIN_ID=80002
EXPO_PUBLIC_NETWORK=polygon-amoy
EXPO_PUBLIC_RPC_URL=<YOUR_RPC_URL>
EXPO_PUBLIC_STATE_CONTRACT_ADDRESS=<STATE_CONTRACT_ADDRESS>
EXPO_PUBLIC_UNIVERSAL_VERIFIER_ADDRESS=<UNIVERSAL_VERIFIER_ADDRESS>
EXPO_PUBLIC_MTP_VALIDATOR_ADDRESS=<MTP_VALIDATOR_ADDRESS>
EXPO_PUBLIC_ISSUER_BASE_URL=<ISSUER_BASE_URL>
EXPO_PUBLIC_ISSUER_DID=<ISSUER_DID>
EXPO_PUBLIC_CREDENTIAL_SCHEMA=<CREDENTIAL_SCHEMA_URL>
EXPO_PUBLIC_CREDENTIAL_CONTEXT=<CREDENTIAL_CONTEXT_URL>
EXPO_PUBLIC_CREDENTIAL_TYPE=PersonCredential
EXPO_PUBLIC_REQUEST_ID=<REQUEST_ID>
EXPO_PUBLIC_CHALLENGE_ADDRESS=<CHALLENGE_ADDRESS>
EXPO_PUBLIC_DID_RESOLVER_URL=<DID_RESOLVER_URL>
EXPO_PUBLIC_CIRCUITS_BASE_URL=<CIRCUITS_BASE_URL>

# Never put private keys, seed phrases, issuer Basic Auth, or production secrets
# in EXPO_PUBLIC_* variables. EXPO_PUBLIC_* values are bundled into the app.
#
# Optional local-only demo value. Keep it in an untracked .env file only.
# DEMO_EVM_PRIVATE_KEY=<LOCAL_ONLY_NOT_COMMITTED>
