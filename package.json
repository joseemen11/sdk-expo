{
  "name": "@privado-id/expo-sdk",
  "version": "0.1.0",
  "description": "Privado ID SDK for Expo and React Native.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "react-native": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:smoke": "node scripts/smoke.cjs",
    "smoke": "npm run test:smoke",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@0xpolygonid/js-sdk": "^1.44.0",
    "@iden3/js-crypto": "^1.3.2",
    "@iden3/js-iden3-core": "^1.8.0",
    "@iden3/js-merkletree": "^1.5.1",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "ethers": "6.15.0"
  }
}
